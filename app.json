{
  "expo": {
    "name": "NATO Phonetics",
    "slug": "nato-phonetics",
    "version": "1.0.0",
    "description": "Learn, practice, and master the NATO phonetic alphabet with interactive tools, quizzes, and audio pronunciation guides.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "natophonetics",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "privacy": "public",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.natophonetics.app"
    },
    "android": {
      "package": "com.natophonetics.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
